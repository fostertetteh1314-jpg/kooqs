# ─── Database (Neon PostgreSQL) ───────────────────────────────
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&connect_timeout=60"

# ─── NextAuth ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="generate-a-random-32-byte-base64-string"
NEXTAUTH_URL="https://your-app.onrender.com"

# ─── Admin bootstrap (used once by npm run db:seed) ───────────
ADMIN_BOOTSTRAP_EMAIL="admin@yourdomain.com"
ADMIN_BOOTSTRAP_PASSWORD="choose-a-strong-password"

# ─── Email (Gmail SMTP) ───────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
FROM_EMAIL="Kooqs Takeout <your-email@gmail.com>"
ADMIN_EMAIL="your-email@gmail.com"

# ─── Cloudinary (image uploads) ───────────────────────────────
# Sign up free at cloudinary.com → Dashboard → copy these values
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Restaurant public info ───────────────────────────────────
NEXT_PUBLIC_RESTAURANT_NAME="Kooqs.Takeout"
NEXT_PUBLIC_RESTAURANT_PHONE="055 090 7888 / 055 470 4380"
NEXT_PUBLIC_RESTAURANT_ADDRESS="Ayensu, Behind Block Factory"
NEXT_PUBLIC_DELIVERY_FEE="10"
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD="150"

# ─── MOMO Payment (leave blank to hide a network) ─────────────
NEXT_PUBLIC_MOMO_MTN_NUMBER="055 090 7888"
NEXT_PUBLIC_MOMO_MTN_NAME="Kooqs Takeout"
NEXT_PUBLIC_MOMO_VODAFONE_NUMBER="055 470 4380"
NEXT_PUBLIC_MOMO_AIRTELTIGO_NUMBER=""
NEXT_PUBLIC_MOMO_INSTRUCTIONS="Send the exact total to any number above. Use your name as the reference. We will call you to confirm before we start preparing your order."
